 void Workspace::disableGlobalShortcutsForClient(bool disable)
 {
-    if (m_globalShortcutsDisabledForWindow == disable) {
+    setGlobalShortcutBlockingForClient(disable, false);
+}
+
+void Workspace::setGlobalShortcutBlockingForClient(bool disable, bool selective)
+{
+    const GlobalShortcutBlocking blocking = disable ? GlobalShortcutBlocking::All : selective ? GlobalShortcutBlocking::Selective
+                                                                                              : GlobalShortcutBlocking::None;
+    if (m_globalShortcutBlockingForWindow == blocking) {
         return;
     }
 #ifdef KWIN_BUILD_GLOBALSHORTCUTS
-    QDBusMessage message = QDBusMessage::createMethodCall(QStringLiteral("org.kde.kglobalaccel"),
-                                                          QStringLiteral("/kglobalaccel"),
-                                                          QStringLiteral("org.kde.KGlobalAccel"),
-                                                          QStringLiteral("blockGlobalShortcuts"));
-    message.setArguments(QList<QVariant>() << disable);
-    QDBusConnection::sessionBus().asyncCall(message);
+    auto callGlobalAccel = [](const QString &method, bool enabled) {
+        QDBusMessage message = QDBusMessage::createMethodCall(QStringLiteral("org.kde.kglobalaccel"),
+                                                              QStringLiteral("/kglobalaccel"),
+                                                              QStringLiteral("org.kde.KGlobalAccel"),
+                                                              method);
+        message.setArguments(QList<QVariant>() << enabled);
+        QDBusConnection::sessionBus().asyncCall(message);
+    };
+
+    if (m_globalShortcutBlockingForWindow == GlobalShortcutBlocking::All) {
+        callGlobalAccel(QStringLiteral("blockGlobalShortcuts"), false);
+    } else if (m_globalShortcutBlockingForWindow == GlobalShortcutBlocking::Selective) {
+        callGlobalAccel(QStringLiteral("blockGlobalShortcutsSelective"), false);
+    }
+
+    if (blocking == GlobalShortcutBlocking::All) {
+        callGlobalAccel(QStringLiteral("blockGlobalShortcuts"), true);
+    } else if (blocking == GlobalShortcutBlocking::Selective) {
+        callGlobalAccel(QStringLiteral("blockGlobalShortcutsSelective"), true);
+    }
 #endif
 
-    m_globalShortcutsDisabledForWindow = disable;
+    m_globalShortcutBlockingForWindow = blocking;
 }
 
