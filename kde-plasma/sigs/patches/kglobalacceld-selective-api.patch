+QStringList GlobalShortcutsRegistry::selectiveGlobalShortcutAllowList() const
+{
+    const QString path = selectiveGlobalShortcutAllowListFilePath();
+    if (path.isEmpty()) {
+        return {};
+    }
+
+    QFile file(path);
+    if (!file.exists()) {
+        return {};
+    }
+    if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
+        qCWarning(KGLOBALACCELD) << "Could not read selective allowlist from" << path;
+        return {};
+    }
+
+    QStringList allowedActions;
+    QTextStream stream(&file);
+    while (!stream.atEnd()) {
+        QString line = stream.readLine();
+        const qsizetype commentIndex = line.indexOf(QLatin1Char('#'));
+        if (commentIndex >= 0) {
+            line.truncate(commentIndex);
+        }
+        line = line.trimmed();
+        if (!line.isEmpty()) {
+            allowedActions.append(line);
+        }
+    }
+    return allowedActions;
+}
+
+void GlobalShortcutsRegistry::setSelectiveGlobalShortcutAllowList(const QStringList &allowedActions)
+{
+    const QString path = selectiveGlobalShortcutAllowListFilePath();
+    if (path.isEmpty()) {
+        return;
+    }
+
+    QDir().mkpath(QFileInfo(path).absolutePath());
+
+    QFile file(path);
+    if (!file.open(QIODevice::WriteOnly | QIODevice::Text | QIODevice::Truncate)) {
+        qCWarning(KGLOBALACCELD) << "Could not write selective allowlist to" << path;
+        return;
+    }
+
+    QTextStream stream(&file);
+    stream << "# Selective global shortcut action allowlist.\n"
+              "#\n"
+              "# Format:\n"
+              "#   component/action\n"
+              "#\n"
+              "# These are KDE global shortcut action identifiers, not physical key bindings.\n";
+    for (const QString &actionId : allowedActions) {
+        stream << actionId << '\n';
+    }
+    file.close();
+}
+
+QString GlobalShortcutsRegistry::selectiveGlobalShortcutAllowListFilePath() const
+{
+    return getSelectiveAllowListFilePath();
+}
