+void KGlobalAccelD::blockGlobalShortcutsSelective(bool block)
+{
+    qCDebug(KGLOBALACCELD) << "Block global shortcuts selectively?" << block;
+    if (block) {
+        d->m_registry->deactivateShortcutsExcept(true, d->m_registry->selectiveGlobalShortcutAllowList());
+    } else {
+        d->m_registry->activateShortcuts();
+    }
+}
