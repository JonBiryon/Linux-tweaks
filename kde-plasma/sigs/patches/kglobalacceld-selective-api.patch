+void Component::deactivateShortcutsExcept(bool temporarily, const QStringList &allowedActions)
+{
+    for (GlobalShortcut *shortcut : std::as_const(_current->_actionsMap)) {
+        const QString actionId = _uniqueName + QLatin1Char('/') + shortcut->uniqueName();
+        if (temporarily //
+            && (_uniqueName == QLatin1String("kwin") && shortcut->uniqueName() == QLatin1String("Block Global Shortcuts"))) {
+            continue;
+        }
+        if (allowedActions.contains(actionId)) {
+            continue;
+        }
+        shortcut->setInactive();
+    }
+}
